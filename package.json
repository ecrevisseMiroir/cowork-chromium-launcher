{
  "name": "chromium-mcp",
  "version": "1.0.0",
  "description": "MCP server that launches Chromium on the local machine",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "chromium-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "bundle": "esbuild src/index.ts --bundle --platform=node --target=node18 --outfile=dist/index.js --format=esm --banner:js='import{createRequire}from\"module\";const require=createRequire(import.meta.url);'",
    "pack": "npm run bundle && mcpb pack",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@anthropic-ai/mcpb": "^2.1.2",
    "@types/node": "^25.6.0",
    "esbuild": "^0.28.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
